{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@scaffold/app": [
        "../../packages/app"
      ],
      "@scaffold/app/*": [
        "../../packages/app/*"
      ],
      "@scaffold/ui": [
        "../../packages/ui/src"
      ],
      "@scaffold/ui/*": [
        "../../packages/ui/src/*"
      ]
    },
    "allowJs": true,
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
